index 9ca274ee7256e92d5af2853c1073bb7fbdc3a194..d6dd541a2906b306fd39160a4f973d2070ad0f95
--- a/TaylorSeer-DiT/taylor_utils/__init__.py
+++ b/TaylorSeer-DiT/taylor_utils/__init__.py
@@ -332,42 +332,30 @@
 
 def pade_formula_mn(cache_dic: Dict, current: Dict) -> torch.Tensor:
     """
-    Single-step weighted-Taylor family behind the historical Padé entrypoint.
+    Ultra-sparse weighted-Taylor family behind the historical Padé entrypoint.
 
-    The latency target for the frozen interval-3 bucket is close to pure Taylor,
-    so this probe avoids tensor-wise gating and instead applies a fixed,
-    conservative cubic damping on the single-step path. Everywhere else it
-    falls back to the original Taylor expansion.
+    Keep the common path as close to pure Taylor as possible: only the last-layer
+    MLP in the very last denoising steps gets a conservative cubic damping.
     Drop-in replacement for taylor_formula.
     """
     x = current["step"] - current["activated_steps"][-1]
     factors = cache_dic["cache"][-1][current["layer"]][current["module"]]
+    use_weighted_taylor = (
+        cache_dic.get("enable_pade", False)
+        and (not cache_dic.get("pade_only_single_step", True) or abs(x) == 1)
+        and len(factors) >= 4
+        and current.get("module") == "mlp"
+        and current.get("layer") == (len(cache_dic["cache"][-1]) - 1)
+        and current["step"] <= 2
+    )
 
-    if not _should_use_pade(cache_dic, current, factors):
-        taylor_output = _taylor_from_factors(factors, x)
-        _record_approx_mode(cache_dic, current, "taylor")
-        _maybe_print_approx_stats(cache_dic, current)
-        return taylor_output
+    taylor_output = 0
+    for i in range(len(factors)):
+        taylor_output += (1 / math.factorial(i)) * factors[i] * (x ** i)
 
-    if len(factors) < 4:
-        taylor_output = _taylor_from_factors(factors, x)
-        _record_approx_mode(cache_dic, current, "taylor")
-        _maybe_print_approx_stats(cache_dic, current)
-        return taylor_output
-
-    if not _is_last_layer_mlp(cache_dic, current):
-        taylor_output = _taylor_from_factors(factors, x)
-        _record_approx_mode(cache_dic, current, "taylor")
-        _maybe_print_approx_stats(cache_dic, current)
-        return taylor_output
-
-    if current["step"] > 8:
-        taylor_output = _taylor_from_factors(factors, x)
-        _record_approx_mode(cache_dic, current, "taylor")
-        _maybe_print_approx_stats(cache_dic, current)
+    if not use_weighted_taylor:
         return taylor_output
 
-    taylor_output = _taylor_from_factors(factors, x)
     cubic = (factors[3] / 6.0) * (x ** 3)
     cubic_retention = 0.5
     output = taylor_output - ((1.0 - cubic_retention) * cubic)

