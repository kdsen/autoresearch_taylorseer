diff --git a/TaylorSeer-DiT/taylor_utils/__init__.py b/TaylorSeer-DiT/taylor_utils/__init__.py
index 5ec30a35852f4730ec7588dfdebf2b572d188986..478aea60a36821f8fe15046e5af3c5e93fba1e38
--- a/TaylorSeer-DiT/taylor_utils/__init__.py
+++ b/TaylorSeer-DiT/taylor_utils/__init__.py
@@ -219,6 +219,53 @@
     return a, b
 
 
+def _evaluate_pade_12(factors, x, denom_threshold=1e-4) -> torch.Tensor:
+    if len(factors) < 4:
+        return _taylor_from_factors(factors, x)
+
+    c0 = factors[0]
+    c1 = factors[1]
+    c2 = factors[2] / 2.0
+    c3 = factors[3] / 6.0
+
+    taylor_output = _taylor_from_factors(factors, x, max_terms=4)
+
+    det = c1 * c1 - c0 * c2
+    det_scale = c1.abs() * c1.abs() + c0.abs() * c2.abs() + 1.0
+    det_ok = det.abs() > (denom_threshold * det_scale)
+    safe_det = torch.where(det_ok, det, torch.ones_like(det))
+
+    b1 = (c0 * c3 - c1 * c2) / safe_det
+    b2 = (c2 * c2 - c1 * c3) / safe_det
+    a0 = c0
+    a1 = c1 + a0 * b1
+
+    numerator = a0 + a1 * x
+    x2 = x * x
+    denominator = 1.0 + b1 * x + b2 * x2
+
+    coeff_finite = (
+        torch.isfinite(a0)
+        & torch.isfinite(a1)
+        & torch.isfinite(b1)
+        & torch.isfinite(b2)
+    )
+    finite_mask = torch.isfinite(numerator) & torch.isfinite(denominator) & coeff_finite
+
+    denom_scale = 1.0 + (b1 * x).abs() + (b2 * x2).abs()
+    local_denom_threshold = denom_threshold * denom_scale
+    denom_ok = denominator.abs() > local_denom_threshold.clamp_min(denom_threshold)
+    safe_mask = det_ok & finite_mask & denom_ok
+
+    safe_denominator = torch.where(safe_mask, denominator, torch.ones_like(denominator))
+    pade_value = numerator / safe_denominator
+
+    denom_margin = denominator.abs() / local_denom_threshold.clamp_min(denom_threshold)
+    blend = torch.clamp(denom_margin - 1.0, min=0.0, max=1.0)
+    blended = blend * pade_value + (1.0 - blend) * taylor_output
+    return torch.where(det_ok & finite_mask, blended, taylor_output)
+
+
 def choose_pade_order_by_available_derivatives(
     factors, forced_order=None, alpha=0.7, max_order=3
 ):
@@ -238,6 +285,9 @@
 
 
 def _evaluate_generic_pade(factors, x, m, n, denom_threshold=1e-4) -> torch.Tensor:
+    if (m, n) == (1, 2):
+        return _evaluate_pade_12(factors, x, denom_threshold=denom_threshold)
+
     max_needed = m + n + 1
     if len(factors) < max_needed:
         return _taylor_from_factors(factors, x)

