def pade_formula_mn(cache_dic: Dict, current: Dict) -> torch.Tensor:
    """
    Single-step weighted-Taylor family behind the historical Padé entrypoint.

    The latency target for the frozen interval-3 bucket is close to pure Taylor,
    so this probe avoids tensor-wise gating and instead applies a fixed,
    conservative cubic damping on the single-step path. Everywhere else it
    falls back to the original Taylor expansion.
    Drop-in replacement for taylor_formula.
    """
    x = current["step"] - current["activated_steps"][-1]
    factors = cache_dic["cache"][-1][current["layer"]][current["module"]]

    if not _should_use_pade(cache_dic, current, factors):
        return _taylor_from_factors(factors, x)

    if len(factors) < 4:
        return _taylor_from_factors(factors, x)

