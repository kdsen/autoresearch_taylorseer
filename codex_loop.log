def cache_init(model_kwargs, num_steps):   
    '''
    Initialization for cache.
    '''
    pade_m = model_kwargs.get('pade_m')
    pade_n = model_kwargs.get('pade_n')
    max_order = model_kwargs['max_order']

    if (pade_m is None) != (pade_n is None):
        raise ValueError("pade_m and pade_n must be set together")
    if pade_m is not None:
        pade_m = int(pade_m)
        pade_n = int(pade_n)
        if pade_m < 1 or pade_n < 1:
            raise ValueError("pade_m and pade_n must both be >= 1")
        if max_order < (pade_m + pade_n):
            raise ValueError(
                f"max_order={max_order} is too small for Padé ({pade_m}, {pade_n}); "
                f"it must be at least {pade_m + pade_n}"
            )
