import math

def pade_coeffs(c,m,n):
    import numpy as np
    rows=[]; rhs=[]
    for row in range(n):
        k=m+1+row
        rhs.append(-c[k])
        rows.append([c[k-col-1] for col in range(n)])
    A=np.array(rows,dtype=float)
    rhs=np.array(rhs,dtype=float)
    b=np.linalg.solve(A,rhs)
    a=[]
    for i in range(m+1):
        s=c[i]
        for j in range(1,min(i,n)+1):
            s += b[j-1]*c[i-j]
        a.append(s)
    return a,b

def series_from_ab(a,b,terms=6):
    import sympy as sp
    x=sp.symbols('x')
    num=sum(sp.Float(ai)*(x**i) for i,ai in enumerate(a))
    den=1+sum(sp.Float(bi)*(x**(i+1)) for i,bi in enumerate(b))
    ser=sp.series(num/den,x,0,terms).removeO()
    return [float(ser.expand().coeff(x,i)) for i in range(terms)]

# exp(x)
ce=[1/math.factorial(k) for k in range(6)]
a,b=pade_coeffs(ce,1,2)
print('exp [1/2] a,b',a,b)
print('series',series_from_ab(a,b,6))

# 1/(1-x)
cr=[1.0]*6
a,b=pade_coeffs(cr,1,2)
print('geom [1/2] a,b',a,b)
print('series',series_from_ab(a,b,6))
